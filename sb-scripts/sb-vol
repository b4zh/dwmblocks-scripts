#!/bin/sh

volh=$(pamixer --get-volume-human)
voln=$(echo "$volh" | tr -d "[=%=]")

case $BLOCK_BUTTON in
	1) st -e pulsemixer;;
	2) st -e "$EDITOR" "$0";;
	3) pavucontrol;;
esac

if [ "$volh" = "muted" ]; then
	echo "$C_DISABLED贈ｨ  ";
elif [ "$voln" = "0" ]; then
	echo "$C_GREEN隥ｦ $C_WHITE$volh "
elif [ "$voln" -gt 0 ] && [ "$voln" -le 50 ]; then
	echo "$C_GREEN隥ｨ  $C_WHITE$volh "
elif [ "$voln" -gt 50 ] && [ "$voln" -le 70 ]; then
	echo "$C_YELLOW隥ｨ  $C_WHITE$volh "
elif [ "$voln" -gt 70 ]; then
	echo "$C_RED隥ｨ  $C_WHITE$volh "
fi
